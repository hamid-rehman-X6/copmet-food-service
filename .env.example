# Use different, randomly generated secrets in every environment.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Public application URL used for same-origin request checks.
APP_URL=

# Admin panel credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Admin WhatsApp number that placed orders are sent to.
# International format, digits only (no +, spaces, or dashes), e.g. 923001234567.
ADMIN_WHATSAPP=

# PostgreSQL config
#
# Production (Neon, etc.): set a single pooled connection string. When
# DATABASE_URL is present it takes precedence and TLS is enabled automatically.
# Use the "-pooler" host for serverless (Vercel).
DATABASE_URL=

# Local development: discrete connection fields, used only when DATABASE_URL is empty.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false
